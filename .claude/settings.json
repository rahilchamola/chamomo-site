{
  "additionalDirectories": [
    "../docs"
  ],
  "permissions": {
    "allow": {
      "Bash": [
        "npx astro *",
        "npm *",
        "git *",
        "npx prettier *"
      ],
      "Read": [
        "**"
      ],
      "Write": [
        "src/**",
        "public/**",
