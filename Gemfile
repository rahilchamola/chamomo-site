source "https://rubygems.org"

gem "jekyll", "~> 4.3"

# Plugins
group :jekyll_plugins do
  gem "jekyll-seo-tag"        # Meta tags, Open Graph, Twitter Cards
  gem "jekyll-feed"           # RSS/Atom feed
  gem "jekyll-sitemap"        # Auto sitemap.xml
  gem "jekyll-redirect-from"  # Redirect old URLs
end
