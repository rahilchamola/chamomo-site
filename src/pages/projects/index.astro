---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/astro/Card.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const active = allProjects.filter(p => p.data.status === 'active');
const completed = allProjects.filter(p => p.data.status === 'completed');
const archived = allProjects.filter(p => p.data.status === 'archive');

// Featured projects get special treatment
const featured = active.filter(p => p.data.featured);
const activeSub = active.filter(p => !p.data.featured);

// Project color mapping (for accent borders)
const projectColors: Record<string, string> = {
  'Shard': '#818cf8',
  'Ultima': '#D4920A',
  'Sophis': '#3EAE7C',
  'Ritmos': '#D946A8',
  'AI Set Curator': '#a855f7',
  'Chamomo.com': '#06b6d4',
  'Chamomo DJ Brand Kit': '#fb923c',
};
---

<BaseLayout title="Projects" description="Things I'm building, have built, and learned from building.">
  <section class="container">
    <div class="content-header">
      <p class="hero-greeting animate-in animate-in-1">Projects</p>
      <h1 class="animate-in animate-in-2">Things I'm building</h1>
      <p class="content-header-description animate-in animate-in-3">
        Active experiments, completed work, and the archived projects that taught me something.
      </p>
      <div class="project-stats animate-in animate-in-4">
        <span class="project-stat"><span class="project-stat-num">{active.length}</span> active</span>
        <span class="project-stat-sep">·</span>
        <span class="project-stat"><span class="project-stat-num">{completed.length}</span> completed</span>
        <span class="project-stat-sep">·</span>
        <span class="project-stat"><span class="project-stat-num">{archived.length}</span> archived</span>
      </div>
    </div>
  </section>

  <!-- Featured / Flagship Projects -->
  {featured.length > 0 && (
    <section class="section--compact container">
      <div class="section-header" data-animate>
        <h2>Flagship</h2>
        <span style="font-size: var(--text-xs); color: var(--text-tertiary); font-family: var(--font-mono);">currently active</span>
      </div>
      <div class="featured-projects">
        {featured.map((project) => {
          const color = projectColors[project.data.title] || '#818cf8';
          const hasSeries = ['Shard', 'Ultima', 'Sophis', 'Ritmos'].includes(project.data.title);
          return (
            <a href={`/projects/${project.id}/`} class="featured-project-card" data-animate>
              <div class="fp-image-col">
                {project.data.image && (
                  <img src={project.data.image} alt={project.data.title} loading="lazy" />
                )}
              </div>
              <div class="fp-content">
                <div class="fp-top">
                  <div class="fp-badges">
                    <span class="badge badge--active">active</span>
                    {hasSeries && <span class="fp-series-badge" style={`color: ${color}; border-color: ${color}30; background: ${color}10;`}>has series ↗</span>}
                  </div>
                  <h3 class="fp-title">{project.data.title}</h3>
                  {project.data.subtitle && <p class="fp-subtitle">{project.data.subtitle}</p>}
                  <p class="fp-description">{project.data.description}</p>
                </div>
                <div class="fp-bottom">
                  {project.data.tech && project.data.tech.length > 0 && (
                    <div class="tech-stack">
                      {project.data.tech.map((t: string) => <span class="tech-pill">{t}</span>)}
                    </div>
                  )}
                </div>
              </div>
              <div class="fp-accent-line" style={`background: linear-gradient(180deg, ${color}, transparent);`}></div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Other Active -->
  {activeSub.length > 0 && (
    <section class="section--compact container">
      <div class="section-header" data-animate>
        <h2>Active</h2>
      </div>
      <div class="card-grid card-grid--2">
        {activeSub.map((project) => (
          <Card
            title={project.data.title}
            description={project.data.description}
            href={`/projects/${project.id}/`}
            image={project.data.image}
            date={project.data.date}
            status={project.data.status}
            type="project"
            tech={project.data.tech}
          />
        ))}
      </div>
    </section>
  )}

  {completed.length > 0 && (
    <section class="section--compact container">
      <div class="section-header" data-animate>
        <h2>Completed</h2>
      </div>
      <div class="card-grid card-grid--2">
        {completed.map((project) => (
          <Card
            title={project.data.title}
            description={project.data.description}
            href={`/projects/${project.id}/`}
            image={project.data.image}
            date={project.data.date}
            status={project.data.status}
            type="project"
            tech={project.data.tech}
          />
        ))}
      </div>
    </section>
  )}

  {archived.length > 0 && (
    <section class="section--compact container">
      <div class="section-header" data-animate>
        <h2>Archive</h2>
        <span style="font-size: var(--text-xs); color: var(--text-tertiary);">projects that taught me something</span>
      </div>
      <div class="card-grid card-grid--2">
        {archived.map((project) => (
          <Card
            title={project.data.title}
            description={project.data.description}
            href={`/projects/${project.id}/`}
            image={project.data.image}
            date={project.data.date}
            status={project.data.status}
            type="project"
            tech={project.data.tech}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .project-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  .project-stat-num {
    font-weight: 700;
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }
  .project-stat-sep { opacity: 0.3; }

  .featured-projects {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .featured-project-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 0;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255,255,255,0.06);
    background: var(--bg-secondary);
    overflow: hidden;
    transition: all 0.3s var(--ease-out);
    position: relative;
  }
  .featured-project-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255,255,255,0.12);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .fp-image-col {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .fp-image-col img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }
  .featured-project-card:hover .fp-image-col img {
    transform: scale(1.05);
  }
  .fp-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .fp-badges {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 0.6rem;
    align-items: center;
  }
  .fp-series-badge {
    font-size: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
    border: 1px solid;
  }
  .fp-title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }
  .fp-subtitle {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: 0.6rem;
    font-style: italic;
  }
  .fp-description {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }
  .fp-bottom {
    padding-top: 0.75rem;
  }
  .fp-accent-line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 3px 0 0 3px;
  }

  @media (max-width: 768px) {
    .featured-project-card {
      grid-template-columns: 1fr;
    }
    .fp-image-col {
      aspect-ratio: 16/9;
    }
  }
</style>
