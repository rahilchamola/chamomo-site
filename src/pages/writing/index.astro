---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Card from '@/components/astro/Card.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique categories
const categories = [...new Set(allPosts.flatMap(p => p.data.categories))];

// Separate series from standalone essays
const seriesMap = new Map<string, typeof allPosts>();
const standalone: typeof allPosts = [];

allPosts.forEach(post => {
  if (post.data.series) {
    const name = post.data.series;
    if (!seriesMap.has(name)) seriesMap.set(name, []);
    seriesMap.get(name)!.push(post);
  } else {
    standalone.push(post);
  }
});

// Sort each series by part number
seriesMap.forEach((posts) => {
  posts.sort((a, b) => (a.data.part ?? 0) - (b.data.part ?? 0));
});

// Series metadata
const seriesMeta: Record<string, { color: string; accent: string; icon: string; tagline: string }> = {
  'Building Shard': { color: '#818cf8', accent: 'indigo', icon: '◇', tagline: 'AI game engine, vibe-coded solo' },
  'Building Ultima': { color: '#D4920A', accent: 'amber', icon: '◎', tagline: 'Unified productivity OS for ADHD' },
  'Building Sophis': { color: '#3EAE7C', accent: 'emerald', icon: '◈', tagline: 'Signal intelligence from noise' },
  'Building Ritmos': { color: '#D946A8', accent: 'magenta', icon: '◐', tagline: 'DJ craft meets product thinking' },
};

const categoryColors: Record<string, string> = {
  ai: '#a855f7',
  creativity: '#f472b6',
  product: '#06b6d4',
  music: '#fb923c',
  building: '#34d399',
  thinking: '#818cf8',
};
---

<BaseLayout title="Writing" description="Essays on AI, music, product, building, and the spaces where they overlap.">
  <section class="container">
    <div class="content-header">
      <p class="hero-greeting animate-in animate-in-1">Writing</p>
      <h1 class="animate-in animate-in-2">Thinking out loud</h1>
      <p class="content-header-description animate-in animate-in-3">
        Essays on AI, music, product thinking, building, and the spaces where they overlap.
      </p>
      <div class="writing-filters animate-in animate-in-4">
        <button class="filter-pill filter-pill--active" data-filter="all">All</button>
        <button class="filter-pill" data-filter="series">Series</button>
        <button class="filter-pill" data-filter="essays">Essays</button>
        <span class="filter-divider"></span>
        {categories.map(cat => {
          const c = categoryColors[cat] || '#818cf8';
          return (
            <button class="filter-pill" data-filter={`cat-${cat}`} style={`--pill-color: ${c};`}>
              <span class="filter-dot" style={`background: ${c};`}></span>
              {cat}
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Series Section -->
  <section class="section--compact container" id="series-section" data-content-type="series">
    <div class="section-header" data-animate>
      <h2>Series</h2>
      <span style="font-size: var(--text-xs); color: var(--text-tertiary); font-family: var(--font-mono);">{seriesMap.size} series · {allPosts.length - standalone.length} parts</span>
    </div>
    <div class="series-grid">
      {[...seriesMap.entries()].map(([name, posts]) => {
        const meta = seriesMeta[name] || { color: '#818cf8', accent: 'indigo', icon: '◇', tagline: '' };
        const firstPost = posts[0];
        return (
          <a href={`/writing/${firstPost.id}/`} class="series-card" data-animate data-categories={posts.flatMap(p => p.data.categories).join(',')}>
            <div class="series-card-accent" style={`background: linear-gradient(135deg, ${meta.color}15 0%, transparent 100%); border-color: ${meta.color}20;`}>
              <div class="series-card-header">
                <div class="series-card-icon" style={`color: ${meta.color}; background: ${meta.color}12; border: 1px solid ${meta.color}25;`}>
                  {meta.icon}
                </div>
                <div class="series-card-meta">
                  <span class="series-card-label" style={`color: ${meta.color};`}>{posts.length}-part series</span>
                  <h3 class="series-card-title">{name}</h3>
                  <p class="series-card-tagline">{meta.tagline}</p>
                </div>
              </div>
              <div class="series-card-parts">
                {posts.map((post, i) => (
                  <div class="series-part-row">
                    <span class="series-part-num" style={`color: ${meta.color}; border-color: ${meta.color}30;`}>{post.data.part ?? i + 1}</span>
                    <span class="series-part-title">{post.data.title.replace(`${name}, `, '').replace(`${name}: `, '').replace(/Part \d+: /, '')}</span>
                  </div>
                ))}
              </div>
              <div class="series-card-cta" style={`color: ${meta.color};`}>
                Start reading →
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Essays Section -->
  <section class="section--compact container" id="essays-section" data-content-type="essays">
    <div class="section-header" data-animate>
      <h2>Essays</h2>
      <span style="font-size: var(--text-xs); color: var(--text-tertiary); font-family: var(--font-mono);">{standalone.length} essays</span>
    </div>
    <div class="card-grid card-grid--3">
      {standalone.map((post) => (
        <div data-categories={post.data.categories?.join(',')}>
          <Card
            title={post.data.title}
            description={post.data.description}
            href={`/writing/${post.id}/`}
            image={post.data.image}
            date={post.data.date}
            category={post.data.categories?.[0]}
            type="post"
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .writing-filters {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: var(--space-5);
  }
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.35em 0.75em;
    border-radius: var(--radius-full);
    border: 1px solid rgba(255,255,255,0.08);
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
    text-transform: capitalize;
  }
  .filter-pill:hover {
    border-color: rgba(255,255,255,0.15);
    color: var(--text-secondary);
  }
  .filter-pill--active {
    background: rgba(168,85,247,0.12);
    border-color: rgba(168,85,247,0.3);
    color: var(--accent-purple);
  }
  .filter-pill[data-filter^="cat-"]:hover,
  .filter-pill[data-filter^="cat-"].filter-pill--active {
    background: color-mix(in srgb, var(--pill-color, #818cf8) 12%, transparent);
    border-color: color-mix(in srgb, var(--pill-color, #818cf8) 30%, transparent);
    color: var(--pill-color, #818cf8);
  }
  .filter-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .filter-divider {
    width: 1px;
    height: 1.2rem;
    background: rgba(255,255,255,0.08);
    margin: 0 0.25rem;
  }
  /* Series grid */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }
  .series-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .series-card-accent {
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 1.5rem;
    transition: all 0.25s;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .series-card:hover .series-card-accent {
    transform: translateY(-3px);
    border-color: rgba(255,255,255,0.12);
  }
  .series-card-header {
    display: flex;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }
  .series-card-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.625rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .series-card-meta {
    flex: 1;
    min-width: 0;
  }
  .series-card-label {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .series-card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0.15rem 0 0;
    line-height: 1.25;
    color: var(--text-primary);
  }
  .series-card-tagline {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin: 0.2rem 0 0;
    line-height: 1.4;
  }
  .series-card-parts {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
    flex: 1;
  }
  .series-part-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.35rem 0;
  }
  .series-part-num {
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 0.375rem;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }
  .series-part-title {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .series-card-cta {
    font-size: var(--text-sm);
    font-weight: 500;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  @media (max-width: 768px) {
    .series-grid { grid-template-columns: 1fr; }
  }
  /* Hidden state for filtering */
  .hidden-filter { display: none !important; }
</style>

<script>
  const pills = document.querySelectorAll('.filter-pill');
  const seriesSection = document.getElementById('series-section');
  const essaysSection = document.getElementById('essays-section');
  const seriesCards = seriesSection?.querySelectorAll('.series-card');
  const essayCards = essaysSection?.querySelectorAll('[data-categories]');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('filter-pill--active'));
      pill.classList.add('filter-pill--active');

      const filter = pill.getAttribute('data-filter');

      if (filter === 'all') {
        seriesSection?.classList.remove('hidden-filter');
        essaysSection?.classList.remove('hidden-filter');
        seriesCards?.forEach(c => (c as HTMLElement).style.display = '');
        essayCards?.forEach(c => (c as HTMLElement).style.display = '');
      } else if (filter === 'series') {
        seriesSection?.classList.remove('hidden-filter');
        essaysSection?.classList.add('hidden-filter');
        seriesCards?.forEach(c => (c as HTMLElement).style.display = '');
      } else if (filter === 'essays') {
        seriesSection?.classList.add('hidden-filter');
        essaysSection?.classList.remove('hidden-filter');
        essayCards?.forEach(c => (c as HTMLElement).style.display = '');
      } else if (filter?.startsWith('cat-')) {
        const cat = filter.replace('cat-', '');
        seriesSection?.classList.remove('hidden-filter');
        essaysSection?.classList.remove('hidden-filter');
        seriesCards?.forEach(c => {
          const cats = c.getAttribute('data-categories') || '';
          (c as HTMLElement).style.display = cats.includes(cat) ? '' : 'none';
        });
        essayCards?.forEach(c => {
          const cats = c.getAttribute('data-categories') || '';
          (c as HTMLElement).style.display = cats.includes(cat) ? '' : 'none';
        });
      }
    });
  });
</script>
